# ── Mode switch ───────────────────────────────────────────────────────────────
# true  → usa datos mock locales (sin backend)
# false → conecta al backend real en VITE_API_BASE_URL
VITE_USE_MOCK=true

# ── Backend URL ───────────────────────────────────────────────────────────────
# Si el backend está en otro host, pon la URL completa aquí.
# Si el backend se sirve desde el mismo host, deja VITE_API_BASE_URL vacío.
# Si el backend expone las rutas bajo /api, deja VITE_API_BASE_PREFIX=/api.
VITE_API_BASE_URL=http://localhost:3001
VITE_API_BASE_PREFIX=/api

# ── Demo token (solo para mock mode) ─────────────────────────────────────────
VITE_DEMO_TOKEN=demo-token-mock
