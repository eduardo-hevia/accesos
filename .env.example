# ── Mode switch ───────────────────────────────────────────────────────────────
# true  → usa datos mock locales (sin backend)
# false → conecta al backend real en VITE_API_BASE_URL
VITE_USE_MOCK=true

# ── Backend URL ───────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3001

# ── Demo token (solo para mock mode) ─────────────────────────────────────────
VITE_DEMO_TOKEN=demo-token-mock
